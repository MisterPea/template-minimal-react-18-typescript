{
  "compilerOptions": {
    "target": "esnext", // Set according to your browser support needs
    "lib": ["dom", "dom.iterable", "esnext"], // Include necessary libraries
    "allowJs": true, // Allow JavaScript files for compatibility
    "skipLibCheck": true, // Avoid checking for missing lib files
    "esModuleInterop": true, // Ensure compatibility with ES modules
    "allowSyntheticDefaultImports": true, // Enable synthetic default imports
    "strict": true, // Enable strict type checking
    "forceConsistentCasingInFileNames": true, // Enforce consistent file naming
    "module": "nodenext", // Choose the output module format
    "moduleResolution": "nodenext", // Enable node-style module resolution
    "jsx": "react-jsx", // Configure JSX handling
    "declaration": true, // Emit type declaration files (.d.ts)
    "outDir": "./dist", // Output directory for compiled JavaScript files
    "sourceMap": true, // Generate source maps for debugging
    "types": [
      // Include necessary type definitions
      "react",
      "react-dom"
    ]
  },
  "include": [
    // Include TypeScript files for compilation
    "src",
    "./webpack.config.js",
    "src/App.tsx",
    "src/index.tsx"
  ],
  "exclude": [
    // Exclude unnecessary directories
    "node_modules",
    "dist"
  ]
}
